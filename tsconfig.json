{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",

    "strict": true,

    "esModuleInterop": true,

    "resolveJsonModule": true,

    "skipLibCheck": true,

    "types": [
      "node",
      "@playwright/test"
    ],

    "baseUrl": ".",

    "paths": {
      "@pages": ["src/pages"],
      "@pages/*": ["src/pages/*"],
      "@components/*": ["src/components/*"],
      "@fixtures": ["src/fixtures"],
      "@fixtures/*": ["src/fixtures/*"],
      "@config/*": ["src/config/*"],
      "@config": ["src/config"],
      "@models": ["src/models"],
      "@models/*": ["src/models/*"],
      "@core/*": ["src/core/*"],
      "@utils/*": ["src/utils/*"]
    }
  },

  "include": [
    "src/**/*.ts",
    "tests/**/*.ts",
    "playwright.config.ts"
  ],

  "exclude": [
    "node_modules"
  ]
}